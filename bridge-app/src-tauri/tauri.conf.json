{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iRacing Setup Bridge",
  "version": "0.1.6",
  "identifier": "com.iracingsetupbridge.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "iRacing Setup Bridge",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#030712"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://iracing-setup-comparison-production.up.railway.app/api/latest-bridge"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1N0NCQjVENTQ0RkJCQTMKUldTanUwOVVYYnQ4TlFUOW9lOEdtc1B5eUU0RWxZTnlHK1VpbWlJOGhpdHhmNDBNdWdBTzZYWFMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
