DATABASE_URL="file:./dev.db"

# Optional: absolute path used in Docker / Railway runtime
# DATABASE_PATH="/app/dev.db"

# Scraper contact email (sent in User-Agent header)
SCRAPER_CONTACT_EMAIL="ricardomrbs1998@gmail.com"

# Grid-and-Go credentials (required for `npm run scrape:grid-and-go`).
# The scraper logs in via Cognito Hosted UI and reads the public datapack
# library that the user's PLUS subscription grants access to. Never commit
# real values; copy this file to .env and fill in.
GRID_AND_GO_EMAIL=
GRID_AND_GO_PASSWORD=
