DATABASE_URL="file:./dev.db"

# Optional: absolute path used in Docker / Railway runtime
# DATABASE_PATH="/app/dev.db"

# Scraper contact email (sent in User-Agent header)
SCRAPER_CONTACT_EMAIL="ricardomrbs1998@gmail.com"

# Grid-and-Go credentials (required for `npm run scrape:grid-and-go`).
# The scraper logs in via Cognito Hosted UI and reads the public datapack
# library that the user's PLUS subscription grants access to. Never commit
# real values; copy this file to .env and fill in.
GRID_AND_GO_EMAIL=
GRID_AND_GO_PASSWORD=

# Bearer token gating POST /api/ingest. Generate with `openssl rand -hex 32`.
# Required in production; optional locally (the route returns 500 if unset).
INGEST_SECRET=

# Round 18: admin dashboard at /admin (Basic Auth via Next middleware).
# ADMIN_PASSWORD must be at least 12 characters; shorter values are treated as
# misconfigured (the middleware returns 503 instead of prompting for creds).
# Generate with: openssl rand -base64 16
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional: GitHub PAT (fine-grained, read-only Contents scope on this repo)
# When set, /releases fetches the live release list from GitHub instead of
# using the hardcoded fallback in app/releases/page.tsx.
GITHUB_TOKEN=
